<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="using:Chat.Desktop"
             xmlns:vm="using:Chat.Desktop.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="Chat.Desktop.MainView"
             x:DataType="vm:MainWindowViewModel">
  
    <Grid RowDefinitions="Auto,*" RowSpacing="10">
		<TextBlock Text="欢迎进入聊天室" />
        <TabbedPage 
            Grid.Row="1" 
            TabPlacement="Left">
            <!-- ✅ 聊天室1 -->
            <ContentPage Header="聊天室1">
                <Grid>
                    <views:ChatView DataContext="{Binding ChatRoom1}"/>
                </Grid>
            </ContentPage>
            <!-- ✅ 聊天室2 -->
            <ContentPage Header="聊天室2">
                <Grid>
                    <views:ChatView DataContext="{Binding ChatRoom2}"/>
                </Grid>
            </ContentPage>
            <ContentPage Header="数据列表">
                <Grid>
                    <views:DataListView/>
                </Grid>
            </ContentPage>
        </TabbedPage>
    </Grid>

</UserControl>